# --- Server ---
PORT=4000
NODE_ENV=development

# SQLite database file (relative to repo root)
DATABASE_URL=./data/app.db

# Auth secrets — CHANGE THESE for any real deployment (min 32 chars each)
JWT_SECRET=dev-access-secret-change-me-please-32chars
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-please-32chars

# CORS: where the client is served from in dev
CLIENT_ORIGIN=http://localhost:5173

# Seeded initial admin account
SEED_ADMIN_EMAIL=admin@ais.local
SEED_ADMIN_PASSWORD=ChangeMe123!

# --- Optional: Claude narrative layer ---
# Leave ANTHROPIC_API_KEY blank to run rules-only (no AI narratives).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Integration adapter modes (simulated by default) ---
EMAIL_INTAKE_MODE=mock
EXPORT_MODE=local
TICKETING_PROVIDER=mock

# --- Dynamics 365 CRM (optional) ---
# Fill in ALL four to switch request intake from sample data to your live Dynamics 365.
# Requires an Azure AD app registration with Dynamics Web API (application user) access.
DYNAMICS_URL=
DYNAMICS_TENANT_ID=
DYNAMICS_CLIENT_ID=
DYNAMICS_CLIENT_SECRET=

# Entra directory source: auto (live Graph when creds present) | graph | mock
DIRECTORY_PROVIDER=auto
